{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "MQTTnet": "Warning",
      "Confluent.Kafka": "Warning"
    }
  },

  "Broker": {
    "Mode": "mqtt",
    "Mqtt": {
      "Host": "localhost",
      "Port": 1883,
      "Topic": "iot.sensors",
      "ClientId": "data-storage-service",
      "QoS": 1
    },
    "Kafka": {
      "BootstrapServers": "localhost:9092",
      "Topic": "iot/sensors",
      "GroupId": "data-storage-group",
      "AutoOffsetReset": "earliest"
    }
  },

  "Database": {
    "ConnectionString": "Host=localhost;Port=5432;Database=iot_db;Username=postgres;Password=postgres"
  },

  "Batching": {
    "BatchSize": 500,
    "FlushIntervalSeconds": 5,
    "DisableWrites": false
  }
}
